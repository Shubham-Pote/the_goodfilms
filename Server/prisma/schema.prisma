// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User{

    id              String @id @default(uuid())
    username        String
    password        String
    gender          Gender
    profilePicture  String?
    description     String?
    role            Role   @default(USER)
    watchHistory    WatchHistory[]
}

model WatchHistory {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  contentId   String   // TMDB or Anilist ID
  contentType String   // "movie", "tv", "anime"
  progressKey String   // Unique string like "movie:123" or "tv:123:1:1"
  progress    Int      // Watch progress percentage
  timestamp   Int?     // Current playback position in seconds
  duration    Int?     // Total duration in seconds
  season      Int?
  episode     Int?
  updatedAt   DateTime @updatedAt

  @@unique([userId, progressKey])
}

enum Gender{

  Male
  Female

}

enum Role {
  USER
  ADMIN
}